#: .\events\templates\events\error403.html:22
msgid "Nothing to see here..."
msgstr "Non c'è niente da vedere qui..."

#: .\events\templates\events\error403.html:25
msgid "It seems like you were trying to do something you were not supposed to!"
msgstr "Sembra che tu stessi provando a fare qualcosa che non dovresti fare!"

#: .\events\templates\events\error403.html:27
msgid ""
"Maybe think about it for a while, then try again...if you still think it's "
"the right thing to do."
msgstr ""
"Magari pensaci su per un po', poi riprova...se pensi che sia la cosa giusta "
"da fare."

#: .\events\templates\events\error404.html:6
#: .\events\templates\events\error404.html:12
msgid "Page not found"
msgstr "Pagina non trovata"

#: .\events\templates\events\error404.html:22
msgid "This isn't the page you're looking for..."
msgstr "Questa non è la pagina che stavi cercando..."

#: .\events\templates\events\error404.html:28
msgid "It looks like you were looking for and event"
msgstr "Sembra che tu stessi cercando un evento"

#: .\events\templates\events\error404.html:28
msgid "but something went wrong."
msgstr "ma qualcosa è andato storto."

#: .\events\templates\events\error404.html:31
msgid "Here some possible explanations, from the most likely:"
msgstr "Ecco alcune possibili spiegazioni, dalla più probabile:"

#: .\events\templates\events\error404.html:33
msgid "The event URL is incorrect"
msgstr "L'URL dell'evento è scorretto"

#: .\events\templates\events\error404.html:34
msgid "The event was deleted and it's no longer available in our systems"
msgstr "L'evento è stato cancellato e non è più disponibile nei nostri sistemi"

#: .\events\templates\events\error404.html:35
msgid "The event never existed"
msgstr "L'evento non è mai esistito"

#: .\events\templates\events\error404.html:36
msgid "A cat, not necessarily yours, walked on your keyboard (you never know)"
msgstr ""
"Un gatto, non necessariamente tuo, è passato sopra la tua tastiera (non si "
"sa mai)"

#: .\events\templates\events\error404.html:37
msgid "The server is grumpy and stopped cooperating (ok, not likely)"
msgstr "Il server è scontroso e ha smesso di cooperare (ok, improbabile)"

#: .\events\templates\events\error404.html:38
msgid "The server exploded (well...maybe not this one)"
msgstr "Il server è espoloso (beh...magari questo no)"

